[Unit]
Description=Checks the current battery level (timer)

Requires=graphical.target multi-user.target
After=graphical.target multi-user.target

[Timer]
OnCalendar=*-*-* *:00,05,10,15,20,25,30,35,40,45,50,55:00
OnStartupSec=1min
RandomizedDelaySec=2min
Persistent=true

[Install]
WantedBy=timers.target battery-monitor.service
